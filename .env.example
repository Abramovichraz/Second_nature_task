SECOND_NATURE_EMAIL=your.email@example.com
SECOND_NATURE_PASSWORD=your-password
SECOND_NATURE_BASE_URL=https://app.secondnature.ai

# Optional. Leave empty to start from SECOND_NATURE_BASE_URL and let the app create a fresh Auth0 state.
SECOND_NATURE_LOGIN_URL=

# Optional. Direct URL to an existing role-play/test screen used by tests/test_roleplay.py.
SECOND_NATURE_ROLEPLAY_URL=

# Optional files used by the structure/presentation parts of the test.
SALESMAN_IMAGE_PATH=assets/salesman.png
RESUME_PDF_PATH=assets/CV.Raz_Abramovich.pdf
LARGE_TEST_FILE_PATH=assets/large_test_file.pdf

# Use false when you want to watch the browser.
HEADLESS=false
SLOW_MO_MS=100
